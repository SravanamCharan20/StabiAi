{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node index.js",
    "dev": "nodemon index.js",
    "install:py-runtime": "python3 -m pip install -r ml/requirements-runtime.txt",
    "generate:employee-data": "python3 ml/generate_enhanced_dataset.py --rows 12000 --seed 42 --output data/enhanced_synthetic_employee_data.csv",
    "train:employee-model": "python3 ml/train_risk_engine_artifacts.py --input data/enhanced_synthetic_employee_data.csv --output data/employee_risk_artifacts.json",
    "refresh:employee-model": "npm run generate:employee-data && npm run train:employee-model",
    "eval:employee-model": "node ml/run_employee_eval.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonrepair": "^3.13.2",
    "mongoose": "^8.13.2",
    "nodemon": "^3.1.9",
    "yahoo-finance2": "^2.13.3"
  }
}
