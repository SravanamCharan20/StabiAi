PORT=9000

# MongoDB connection (required for persistent production data)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Gemini settings
GEMINI_API_KEY=your_google_ai_api_key
GEMINI_MODEL=gemini-2.0-flash

# Optional: custom evaluation dataset path
# EMPLOYEE_EVAL_DATASET_PATH=/opt/render/project/src/backend/data/enhanced_synthetic_employee_data.csv

# Comma-separated allowed frontend origins.
# Supports wildcard with * (example: https://*.vercel.app)
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app,https://*.vercel.app

# Optional: turn off python fallback if needed (1 = enabled, 0 = disabled)
ENABLE_NSE_PYTHON_FALLBACK=1
